# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_SHEETS_WEBHOOK_URL: The Google Apps Script Web App URL to log orders to.
VITE_GOOGLE_SHEETS_WEBHOOK_URL=""

# VITE_HOTEL_NAME: The name of the hotel or restaurant. Defaults to "Fraser Suites Doha".
VITE_HOTEL_NAME="Fraser Suites Doha"

# VITE_GREETING: The initial greeting the agent will say. 
# Defaults to "Fraser Suites in-room dining, would you like to continue in English or Arabic?"
VITE_GREETING="Fraser Suites in-room dining, would you like to continue in English or Arabic?"

# VITE_ADDITIONAL_LANGUAGE: The additional language to offer. 
# To disable the additional language (English only), set this to "None" or "False".
# Defaults to "Arabic".
VITE_ADDITIONAL_LANGUAGE="Arabic"

# VITE_MENU_WORKSHEET_NAME: The name of the worksheet in your Google Sheet that contains the menu.
# Defaults to "Menu".
VITE_MENU_WORKSHEET_NAME="Menu"

# VITE_ORDERS_WORKSHEET_NAME: The name of the worksheet in your Google Sheet where orders are logged.
# Defaults to "Orders".
VITE_ORDERS_WORKSHEET_NAME="Orders"

# VITE_VOICE_NAME: The voice to use for the agent.
# Available options: "Puck", "Charon", "Kore", "Fenrir", "Zephyr".
# Defaults to "Zephyr".
VITE_VOICE_NAME="Zephyr"
